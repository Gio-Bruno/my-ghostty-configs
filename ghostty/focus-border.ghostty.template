# Generated from my-ghostty-configs.
# Source: https://github.com/Gio-Bruno/my-ghostty-configs

keybind = cmd+]=goto_split:next
keybind = cmd+t=new_tab
keybind = cmd+d=new_split:right
keybind = cmd+shift+d=new_split:down
# Prompt you to rename the focused pane/split
keybind = cmd+shift+r=prompt_surface_title
custom-shader = {{FOCUS_BORDER_SHADER}}
custom-shader-animation = true
